{
  "compilerOptions": {
    "baseUrl": "src",
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@lib/*": [
        "lib/*"
      ],
      "@data/*": [
        "data/*"
      ],
      "@hook/*": [
        "hooks/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@context/*": [
        "contexts/*"
      ],
      "@reducer/*": [
        "reducers/*"
      ],
      "@component/*": [
        "components/*"
      ],
      "@sections/*": [
        "page-sections/*"
      ],
      "@models/*": [
        "models/*"
      ],
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist-cpanel",
    "./src/components/icon/Icon.tsx"
  ]
}
